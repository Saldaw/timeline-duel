  inventionImage: {fileID: 21300000, guid: 66d453e78c4425640948ee33c508760a, type: 3}
  description: "\u041B\u0430\u0441\u043B\u043E \u0411\u0438\u0440\u043E, \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0439
    \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442, \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0441\u043A\u0430\u044F
    \u043A\u0440\u0430\u0441\u043A\u0430 \u0441\u043E\u0445\u043D\u0435\u0442 \u0431\u044B\u0441\u0442\u0440\u0435\u0435
    \u0447\u0435\u0440\u043D\u0438\u043B. \u041E\u043D \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0435\u0451
    \u0432 \u0430\u0432\u0442\u043E\u0440\u0443\u0447\u043A\u0435, \u043D\u043E \u0433\u0443\u0441\u0442\u0430\u044F
    \u043A\u0440\u0430\u0441\u043A\u0430 \u043D\u0435 \u0442\u0435\u043A\u043B\u0430
    \u043A \u043F\u0435\u0440\u0443. \u0422\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u0431\u0440\u0430\u0442-\u0445\u0438\u043C\u0438\u043A \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0448\u0430\u0440\u0438\u043A\u043E\u0432\u044B\u0439 \u043D\u0430\u043A\u043E\u043D\u0435\u0447\u043D\u0438\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u0438 \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B \u043A\u0440\u0430\u0441\u043A\u0443
    \u043D\u0430 \u0431\u0443\u043C\u0430\u0433\u0443."
