  inventionImage: {fileID: 21300000, guid: 7f7fba427086fb04f85c450f9a19cac0, type: 3}
  description: "\u0410\u043B\u044C\u0444\u0440\u0435\u0434 \u041D\u043E\u0431\u0435\u043B\u044C
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0434\u0438\u043D\u0430\u043C\u0438\u0442
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043D\u0438\u0442\u0440\u043E\u0433\u043B\u0438\u0446\u0435\u0440\u0438\u043D.
    \u041A\u043E\u0433\u0434\u0430 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0431\u0443\u0442\u044B\u043B\u0435\u0439
    \u0440\u0430\u0437\u0431\u0438\u043B\u0430\u0441\u044C, \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C
    \u0432\u043F\u0438\u0442\u0430\u043B\u0430\u0441\u044C \u0432 \u043A\u0438\u0437\u0435\u043B\u044C\u0433\u0443\u0440
    (\u0434\u0438\u0430\u0442\u043E\u043C\u043E\u0432\u0443\u044E \u0437\u0435\u043C\u043B\u044E),
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u0430\u044F
    \u0432\u0437\u0440\u044B\u0432\u0447\u0430\u0442\u043A\u0430. \u041C\u0443\u0447\u0438\u043C\u044B\u0439
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u0432\u0438\u043D\u044B \u0437\u0430
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0432\u043E\u0439\u043D\u0430\u0445,
    \u043E\u043D \u0437\u0430\u0432\u0435\u0449\u0430\u043B \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043F\u0440\u0435\u043C\u0438\u044E \u043C\u0438\u0440\u0430."
