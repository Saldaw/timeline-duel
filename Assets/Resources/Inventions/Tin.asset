  inventionImage: {fileID: 21300000, guid: 706b65be1b67ca247a95738b1e64c137, type: 3}
  description: "\u041A\u043E\u043D\u0441\u0435\u0440\u0432\u043D\u0443\u044E \u0431\u0430\u043D\u043A\u0443
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B\u0438 \u0432 1810 \u0433\u043E\u0434\u0443,
    \u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0448\u043A\u0443 \u0434\u043B\u044F
    \u043D\u0435\u0451 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043F\u0443\u0441\u0442\u044F \u043F\u043E\u0447\u0442\u0438 50 \u043B\u0435\u0442.
    \u0414\u043E \u044D\u0442\u043E\u0433\u043E \u0431\u0430\u043D\u043A\u0438 \u0432\u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0438
    \u043C\u043E\u043B\u043E\u0442\u043A\u043E\u043C \u0438 \u0437\u0443\u0431\u0438\u043B\u043E\u043C,
    \u0430 \u0441\u043E\u043B\u0434\u0430\u0442\u044B \u0438\u043D\u043E\u0433\u0434\u0430
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438 \u0448\u0442\u044B\u043A\u0438."
